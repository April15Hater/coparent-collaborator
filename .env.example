# ── Shared Portal Config ───────────────────────────────────────────────────

# Server
HOST=0.0.0.0
PORT=8443

# Secret key for JWT signing (generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=change-me

# Sync API key for automated integrations
SYNC_API_KEY=change-me

# Public URL (used in email notifications)
APP_URL=https://coparent.yourdomain.com

# ── Cloudflare Access ───────────────────────────────────────────────────────
CF_TEAM_DOMAIN=your-team-name
CF_AUD=your-application-aud-tag

# ── Custody Schedule ───────────────────────────────────────────────────────
ACE_ON_WEEK_ANCHOR=2026-03-13
TIMEZONE=America/New_York

# ── SMTP (for email notifications) ─────────────────────────────────────────
SMTP_HOST=your-smtp-relay-ip
SMTP_PORT=25
SMTP_FROM=noreply@yourdomain.com

# ── AI Features (tone adjustment, summarize) ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
