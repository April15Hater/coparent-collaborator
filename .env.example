# Ace's Co-Parenting Board — Configuration
# Copy to .env and fill in values.

SECRET_KEY=change-me-generate-a-random-string
SYNC_API_KEY=change-me-sync-key

ACE_ON_WEEK_ANCHOR=2026-03-13
TIMEZONE=America/New_York

# Cloudflare Access
CF_TEAM_DOMAIN=your-team-name
CF_AUD=your-application-aud-tag

# App URL
APP_URL=https://coparent.joeysolomon.com

# AI features (tone adjustment, summarize)
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-haiku-4-5-20251001

# Notifications (SMTP)
SMTP_HOST=192.168.1.24
SMTP_PORT=25
SMTP_FROM=noreply@joeysolomon.com
